# Server-only. Never expose this value through NEXT_PUBLIC_* or browser code.
OPENAI_API_KEY=

# Runtime defaults: Terra for judged analysis/PTC and Luna for revision feedback.
OPENAI_MODEL=gpt-5.6-luna
OPENAI_HERO_MODEL=gpt-5.6-terra
# Required in production. Use a random server-only secret of at least 32 characters.
MODELDUEL_EVALUATION_SECRET=
# ModelDuel-specific model overrides. Never expose server keys through NEXT_PUBLIC_* variables.
MODELDUEL_ANALYSIS_MODEL=gpt-5.6-terra
MODELDUEL_REVISION_MODEL=gpt-5.6-luna
# When unset, these fall back to the existing OPENAI_HERO_MODEL and OPENAI_MODEL values above.
# Optional: set only when this origin is reachable exclusively through Cloudflare.
# Vercel is detected from its platform-provided VERCEL=1 environment variable.
MODELDUEL_TRUSTED_PROXY=
# Cloudflare production sets this through wrangler.jsonc. Leave blank for next dev.
MODELDUEL_CLOUDFLARE_RATE_LIMITS=
# Cloudflare production sets this to durable-object. Leave blank for next dev.
MODELDUEL_REVISION_REPLAY=
