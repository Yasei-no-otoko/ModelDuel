{
  "name": "modelduel",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-led conceptual learning through competing runnable models.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.13.0 <12"
  },
  "scripts": {
    "video:submission": "node scripts/record-submission-video.mjs",
    "video:validate:contracts": "node scripts/record-submission-video.mjs --validate-contracts-only",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:workers && pnpm video:validate:contracts && pnpm build",
    "cf:build:raw": "opennextjs-cloudflare build",
    "cf:prepare-assets": "node scripts/prepare-cloudflare-assets.mjs",
    "cf:build": "pnpm cf:build:raw && pnpm cf:prepare-assets",
    "cf:preview": "pnpm cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "pnpm cf:build && opennextjs-cloudflare deploy",
    "cf:upload": "pnpm cf:build && opennextjs-cloudflare upload",
    "cf:typegen": "pnpm cf:build && wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:typecheck": "pnpm cf:build && wrangler types cloudflare-env.d.ts --env-interface CloudflareEnv --check"
  },
  "dependencies": {
    "@react-three/fiber": "9.6.1",
    "next": "16.2.10",
    "openai": "6.47.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@opennextjs/cloudflare": "1.20.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
